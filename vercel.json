{
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/", "destination": "/empirehomepath-v8.html" },
    { "source": "/demo", "destination": "/empirehomepath-demo.html" },
    { "source": "/search", "destination": "/empirehomepath-search.html" },
    { "source": "/privacy", "destination": "/empirehomepath-privacy.html" },
    { "source": "/terms", "destination": "/empirehomepath-terms.html" },
    { "source": "/disclaimer", "destination": "/empirehomepath-disclaimer.html" },
    { "source": "/admin", "destination": "/empirehomepath-admin.html" },
    { "source": "/thankyou", "destination": "/empirehomepath-thankyou.html" },
    { "source": "/app", "destination": "/index.html" },
    { "source": "/app/(.*)", "destination": "/index.html" }
  ]
}
